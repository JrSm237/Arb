PORT=3000

# ── URL DE TON APP (obligatoire pour le keep-alive et le webhook Telegram) ────
APP_URL=https://ton-app.onrender.com

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# 1. Va sur @BotFather → /newbot → récupère le token
# 2. Envoie un message à ton bot → va sur api.telegram.org/bot<TOKEN>/getUpdates
#    pour récupérer ton chat_id
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# ── ADMIN ─────────────────────────────────────────────────────────────────────
# Obligatoire : protège le démarrage/arrêt du bot de trading (argent réel).
# Choisis une valeur longue et aléatoire. Sans elle, le serveur refuse
# toutes les actions sur le bot (start/stop/test-connections/report).
ADMIN_KEY=change-moi-en-quelque-chose-de-long-et-aleatoire

# ── BOT DE TRADING ────────────────────────────────────────────────────────────
# Les clés API des exchanges (Bybit, MEXC, HTX, KuCoin) ne sont PAS mises ici :
# tu les saisis directement depuis le site, à l'étape 2 du panneau bot.
# Elles sont envoyées au serveur à chaque démarrage et stockées localement
# (encodage base64, PAS un chiffrement fort) dans bot_config.json pour permettre
# le redémarrage automatique si le serveur reboot.
MIN_SPREAD_PCT=2.0
CAPITAL_PER_LEG=10
DRY_RUN=true
