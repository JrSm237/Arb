PORT=3000

# ── URL DE TON APP RENDER (obligatoire pour le keep-alive et le webhook Telegram) ──
APP_URL=https://arbiscan-f4fk.onrender.com

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# 1. Va sur @BotFather → /newbot → récupère le token
# 2. Envoie un message à ton bot → va sur api.telegram.org/bot<TOKEN>/getUpdates
#    pour récupérer ton chat_id
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
ALERT_SPREAD=2.0
SCAN_INTERVAL=60000
AUTO_SCAN_PAIRS=50

# ── CLÉS API BOT DE TRADING (optionnel — configurable aussi depuis le site) ───
# OKX : créer clé avec Read + Trade UNIQUEMENT, PAS de Withdraw
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# HTX : créer clé avec Read + Trade UNIQUEMENT, PAS de Withdraw
HTX_API_KEY=
HTX_SECRET=

# Config bot par défaut
MIN_SPREAD_PCT=2.0
CAPITAL_PER_LEG=10
DRY_RUN=true

# ── ADMIN ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=change-moi-en-quelque-chose-de-secret
BOT_PUBLIC_KEY=arbiscan-bot-public
